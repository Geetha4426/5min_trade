# ═══════════════════════════════════════════════════════════════════
# 5min_trade — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# TELEGRAM
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ═══════════════════════════════════════════════════════════════════
# POLYMARKET WALLET (required for LIVE trading only)
# ═══════════════════════════════════════════════════════════════════
# Your MetaMask/EOA private key (0x + 64 hex chars)
# This is the ONLY required field for live trading!
POLY_PRIVATE_KEY=0xYourPrivateKeyHere

# Signature type: 0=EOA/MetaMask (default), 1=Email/Magic, 2=Browser Proxy
# ⚠️ If you signed up via browser (polymarket.com), you likely need type 2!
# Check your order signing message — if "signatureType": "2", set this to 2.
POLY_SIGNATURE_TYPE=2

# Proxy wallet address (REQUIRED for signature_type=2)
# This is the "maker" address from Polymarket's order signing message.
# It's the smart contract wallet that holds your actual USDC.
# Find it: place a test trade on polymarket.com → check the "maker" field in the signing popup.
POLY_PROXY_WALLET=0xYourProxyWalletAddress

# Funder address (auto-derived for EOA; uses POLY_PROXY_WALLET for type 2)
# Only set this to override the auto-derived funder address.
# POLY_FUNDER_ADDRESS=0xYourPolymarketSafeAddress

# ⚠️ DO NOT SET THESE — they are AUTO-DERIVED from your private key!
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_PASSPHRASE=

# ═══════════════════════════════════════════════════════════════════
# PROXY (required on Railway — all regions are geoblocked!)
# ═══════════════════════════════════════════════════════════════════
# Route API calls through a proxy in a non-blocked country (IN, JP, BR, KR)
# Get one from webshare.io or run your own on a VPS
# Formats: http://user:pass@host:port  |  socks5://user:pass@host:port
# PROXY_URL=http://user:pass@proxy-host:8080

# ═══════════════════════════════════════════════════════════════════
# TRADING
# ═══════════════════════════════════════════════════════════════════
TRADING_MODE=paper
STARTING_BALANCE=100.0
ENABLED_COINS=BTC,ETH,SOL
ENABLED_TIMEFRAMES=5,15
LIVE_RISK_MODE=concentration

# RISK
MAX_DAILY_LOSS_PCT=15.0
MAX_TOTAL_POSITIONS=10

# STRATEGY TUNING
FLASH_DROP_THRESHOLD=0.25
ORACLE_PRICE_BUFFER=0.005
ARB_MAX_COMBINED_PRICE=0.98
